# Database
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appdb

# Anthropic
ANTHROPIC_API_KEY=

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_TO_NUMBER=+1xxxxxxxxxx

# YouTube Data API v3
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=          # UCxxxxxxxxxxxxxxxxxxxxxxxx — find in YouTube Studio → Settings → Advanced

# YouTube OAuth (comment deletion)
# credentials/youtube_oauth_token.json must be generated via the one-time OAuth
# authorization flow before comment deletion will work. The flow requires a
# desktop OAuth client secret (credentials/youtube_client_secret.json) and the
# youtube.force-ssl scope. Once generated, the token is auto-refreshed by the
# Streamlit container — no manual renewal needed.

# Gmail OAuth — paths to credential JSON files inside /app/credentials
GMAIL_EBAY_TOKEN_PATH=/app/credentials/gmail_ebay_token.json
GMAIL_YOUTUBE_TOKEN_PATH=/app/credentials/gmail_youtube_token.json

# eBay import folder (maps to container path)
EBAY_IMPORT_FOLDER=/app/imports
